o ivo  4039 Apr  6 13:18 INTEGRATION.md\ndrwxrwxr-x  2 ivo ivo  4096 Apr  3 10:19 memory\n-rw-rw-r--  1 ivo ivo  1289 Mar 29 03:02 MEMORY.md\ndrwxrwxr-x  2 ivo ivo  4096 Apr  3 10:22 .openclaw\n-rw-rw-r--  1 ivo ivo  4451 Mar 29 13:13 PROMPTS.md\ndrwxrwxr-x  3 ivo ivo  4096 Mar 29 01:44 scripts\ndrwxrwxr-x  5 ivo ivo  4096 Mar 31 18:42 skills\n-rw-rw-r--  1 ivo ivo  1699 Apr  2 22:43 SOUL.md\n-rw-rw-r--  1 ivo ivo  2089 Apr  2 22:41 SOUL.md.bak.20260402-224145\ndrwxrwxr-x  2 ivo ivo  4096 Apr  6 14:06 state\ndrwxrwxr-x  2 ivo ivo  4096 Mar 29 12:39 templates\n-rw-rw-r--  1 ivo ivo   840 Mar 29 03:00 TOOLS.md\n-rw-rw-r--  1 ivo ivo  2574 Mar 29 14:39 USER.md","cwd":"/home/ivo/.openclaw/workspace"},"isError":false,"timestamp":1776108755216}}
