d\": False,\n                            \"color\": \"green\"\n                        }\n                    },\n                    {\n                        \"type\": \"text\",\n                        \"text\": {\n                            \"content\": \"▱▱▱▱\",\n                            \"link\": None\n                        },\n                        \"annotations\": {\n                            \"bold\": False,\n                            \"color\": \"gray\"\n                        }\n                    },\n                    {\n                        \"type\": \"text\",\n                        \"text\": {\n                            \"content\": \" (70%)\",\n                            \"link\": None\n                        },\n                        \"annotations\": {\n                            \"bold\": False,\n                            \"color\": \"default\"\n                        }\n                    }\n                ],\n                \"color\": \"default\"\n            }\n        },\n        {\n            \"object\": \"block\",\n            \"type\": \"paragraph\",\n            \"paragraph\": {\n                \"rich_text\": [\n                    {\n                        \"type\": \"text\",\n                        \"text\": {\n                            \"content\": \"Update this daily based on what you complete!\",\n                            \"link\": None\n                        },\n                        \"annotations\": {\n                            \"italic\": True,\n                            \"color\": \"gray\"\n                        }\n                    }\n                ],\n                \"color\": \"default\"\n            }\n        },\n        {\n            \"object\": \"block\",\n            \"type\": \"divider\",\n            \"divider\": {}\n        }\n    ]\n}\n\nprint(\"Adding progress tracker...\")\ntry:\n    url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n    response = requests.patch(url, headers=headers, json=progress_data)\n    \n    if response.status_code == 200:\n        print(\"✅ Added progress tracker successfully!\")\n    else:\n        print(f\"❌ Failed to add progress tracker: {response.status_code}\")\n        print(response.text)\n        \nexcept Exception as e:\n    print(f\"Error: {e}\")\n\n# Now let's add some color to the yearly goals (make them stand out)\nprint(\"\\nUpdating yearly goals with colors...\")\ntry:\n    # Get all blocks\n    url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n    response = requests.get(url, headers=headers)\n    blocks = response.json().get('results', [])\n    \n    yearly_heading_index = None\n    for i, block in enumerate(blocks):\n        if block.get('type') == 'heading_2':\n            text = block.get('heading_2', {}).get('rich_text', [])\n            if text and text[0].get('plain_text', '').startswith('🎯 Yearly'):\n                yearly_heading_index = i\n                break\n    \n    if yearly_heading_index is not None:\n        # Update the heading with color\n        heading_id = blocks[yearly_heading_index]['id']\n        update_url = f\"https://api.notion.com/v1/blocks/{heading_id}\"\n        \n        update_data = {\n            \"heading_2\": {\n                \"rich_text\": [\n                    {\n                        \"type\": \"text\",\n                        \"text\": {\n                            \"content\": \"🎯 Yearly (12-Month) Goals\",\n                            \"link\": None\n                        },\n                        \"annotations\": {\n                            \"bold\": True,\n                            \"color\": \"orange\"\n                        }\n                    }\n                ]\n            }\n        }\n        \n        response = requests.patch(update_url, headers=headers, json=update_data)\n        if response.status_code == 200:\n            print(\"✅ Updated yearly heading with orange color!\")\n        else:\n            print(f\"❌ Failed to update heading: {response.status_code}\")\n            \nexcept Exception as e:\n    print(f\"Error: {e}\")\n\nprint(\"\\nDone!\")"}}],"api":"openai-completions","provider":"nvidia","model":"deepseek-ai/deepseek-v3.2","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774742425648,"responseId":"f6d44621f71e433e92539865b6eb81dd"}}
