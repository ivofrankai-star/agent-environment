{"type":"message","id":"d3bfdd9e","parentId":"4355f1b4","timestamp":"2026-03-29T00:07:14.264Z","message":{"role":"assistant","content":[{"type":"text","text":"Got it. Let me add more visual elements systematically. I'll:\n\n1. **Add colors to priorities** (Daily = green, Monthly = blue, Yearly = orange)\n2. **Add a \"Today's Focus\" toggle list** \n3. **Add icons to each todo** (instead of just checkboxes)\n4. **Add a"},{"type":"toolCall","id":"call_8ffddf84e18745bba15086b6","name":"write","arguments":{"file_path":"/home/ivo/.openclaw/workspace/visual_overhaul.py","content":"#!/usr/bin/env python3\nimport os\nimport requests\nimport json\n\n# Get Notion API key from environment\nNOTION_KEY = \"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\"\nPAGE_ID = \"331996240a6680268f4bc68282b2bba6\"\n\nheaders = {\n    \"Authorization\": f\"Bearer {NOTION_KEY}\",\n    \"Notion-Version\": \"2022-06-28\",\n    \"Content-Type\": \"application/json\"\n}\n\ndef add_toggle_focus():\n    \"\"\"Add a toggle list for Today's Focus after the callout\"\"\"\n    print(\"Adding Today's Focus toggle...\")\n    \n    toggle_data = {\n        \"children\": [\n            {\n                \"object\": \"block\",\n                \"type\": \"toggle\",\n                \"toggle\": {\n                    \"rich_text\": [\n                        {\n                            \"type\": \"text\",\n                            \"text\": {\n                                \"content\": \"🎯 Today's Focus\",\n                                \"link\": None\n                            },\n                            \"annotations\": {\n                                \"bold\": True,\n                                \"color\": \"green\"\n                            }\n                        }\n                    ],\n                    \"color\": \"green_background\",\n                    \"children\": [\n                        {\n                            \"object\": \"block\",\n                            \"type\": \"paragraph\",\n                            \"paragraph\": {\n                                \"rich_text\": [\n                                    {\n                                        \"type\": \"text\",\n                                        \"text\": {\n                                            \"content\": \"• Pick ONE main task from Daily section\",\n                                            \"link\": None\n                                        },\n                                        \"annotations\": {\n                                            \"color\": \"default\"\n                                        }\n                                    }\n                                ]\n                            }\n                        },\n                        {\n                            \"object\": \"block\",\n                            \"type\": \"paragraph\",\n                            \"paragraph\": {\n                                \"rich_text\": [\n                                    {\n                                        \"type\": \"text\",\n                                        \"text\": {\n                                            \"content\": \"• Work on it for 2-4h without distractions\",\n                                            \"link\": None\n                                        },\n                                        \"annotations\": {\n                                            \"color\": \"default\"\n                                        }\n                                    }\n                                ]\n                            }\n                        },\n                        {\n                            \"object\": \"block\",\n                            \"type\": \"paragraph\",\n                            \"paragraph\": {\n                                \"rich_text\": [\n                                    {\n                                        \"type\": \"text\",\n                                        \"text\": {\n                                            \"content\": \"• Update progress bar when complete\",\n                                            \"link\": None\n                                        },\n                                        \"annotations\": {\n                                            \"color\": \"default\"\n                                        }\n                                    }\n                                ]\n                            }\n                        }\n                    ]\n                }\n            }\n        ]\n    }\n    \n    try:\n        url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n        response = requests.patch(url, headers=headers, json=toggle_data)\n        \n        if response.status_code == 200:\n            print(\"✅ Added Today's Focus toggle!\")\n        else:\n            print(f\"❌ Failed to add toggle: {response.status_code}\")\n            print(response.text)\n            \n    except Exception as e:\n        print(f\"Error: {e}\")\n\ndef add_visual_key():\n    \"\"\"Add a visual key/legend for priority colors\"\"\"\n    print(\"\\nAdding visual key...\")\n    \n    key_data = {\n        \"children\": [\n            {\n                \"object\": \"block\",\n                \"type\": \"callout\",\n                \"callout\": {\n                    \"rich_text\": [\n                        {\n                            \"type\": \"text\",\n                            \"text\": {\n                                \"content\": \"Priority Key: \",\n                                \"link\": None\n                            },\n                            \"annotations\": {\n                                \"bold\": True\n                            }\n                        },\n                        {\n                            \"type\": \"text\",\n                            \"text\": {\n                                \"content\": \"🟢 Daily \",\n                                \"link\": None\n                            },\n                            \"annotations\": {\n                                \"color\": \"green\"\n                            }\n                        },\n                        {\n                            \"type\": \"text\",\n                            \"text\": {\n                                \"content\": \"🔵 Monthly \",\n                                \"link\": None\n                            },\n                            \"annotations\": {\n                                \"color\": \"blue\"\n                            }\n                        },\n                        {\n                            \"type\": \"text\",\n                            \"text\": {\n                                \"content\": \"🟠 Yearly\",\n                                \"link\": None\n                            },\n                            \"annotations\": {\n                                \"color\": \"orange\"\n                            }\n                        }\n                    ],\n                    \"icon\": {\n                        \"emoji\": \"🗝️\"\n                    },\n                    \"color\": \"gray_background\"\n                }\n            }\n        ]\n    }\n    \n    try:\n        url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n        response = requests.patch(url, headers=headers, json=key_data)\n        \n        if response.status_code == 200:\n            print(\"✅ Added visual key!\")\n        else:\n            print(f\"❌ Failed to add key: {response.status_code}\")\n            print(response.text)\n            \n    except Exception as e:\n        print(f\"Error: {e}\")\n\ndef update_section_colors():\n    \"\"\"Update section headings with colors\"\"\"\n    print(\"\\nUpdating section colors...\")\n    \n    try:\n        # Get all blocks\n        url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n        response = requests.get(url, headers=headers)\n        blocks = response.json().get('results', [])\n        \n        # Update Daily heading to green\n        for i, block in enumerate(blocks):\n            if block.get('type') == 'heading_2':\n                text = block.get('heading_2', {}).get('rich_text', [])\n                if text and text[0].get('plain_text', '').startswith('📅 Daily'):\n                    heading_id = block['id']\n                    update_url = f\"https://api.notion.com/v1/blocks/{heading_id}\"\n                    \n                    update_data = {\n                        \"heading_2\": {\n                            \"rich_text\": [\n                                {\n                                    \"type\": \"text\",\n                                    \"text\": {\n                                        \"content\": \"📅 Daily Goals\",\n                                        \"link\": None\n                                    },\n                                    \"annotations\": {\n                                        \"bold\": True,\n                                        \"color\": \"green\"\n                                    }\n                                }\n                            ]\n                        }\n                    }\n                    \n                    response = requests.patch(update_url, headers=headers, json=update_data)\n                    if response.status_code == 200:\n                        print(\"✅ Updated Daily heading to green!\")\n                    break\n        \n        # Update Monthly heading to blue  \n        for i, block in enumerate(blocks):\n            if block.get('type') == 'heading_2':\n                text = block.get('heading_2', {}).get('rich_text', [])\n                if text and text[0].get('plain_text', '').startswith('📆 Monthly'):\n                    heading_id = block['id']\n                    update_url = f\"https://api.notion.com/v1/blocks/{heading_id}\"\n                    \n                    update_data = {\n                        \"heading_2\": {\n                            \"rich_text\": [\n                                {\n                                    \"type\": \"text\",\n                                    \"text\": {\n                                        \"content\": \"📆 Monthly Goals\",\n                                        \"link\": None\n                                    },\n                                    \"annotations\": {\n                                        \"bold\": True,\n                                        \"color\": \"blue\"\n                                    }\n                                }\n                            ]\n                        }\n                    }\n                    \n                    response = requests.patch(update_url, headers=headers, json=update_data)\n                    if response.status_code == 200:\n                        print(\"✅ Updated Monthly heading to blue!\")\n                    break\n                    \n    except Exception as e:\n        print(f\"Error: {e}\")\n\ndef add_final_divider():\n    \"\"\"Add a decorative divider at the end\"\"\"\n    print(\"\\nAdding decorative divider...\")\n    \n    divider_data = {\n        \"children\": [\n            {\n                \"object\": \"block\",\n                \"type\": \"divider\",\n                \"divider\": {}\n            },\n            {\n                \"object\": \"block\",\n                \"type\": \"paragraph\",\n                \"paragraph\": {\n                    \"rich_text\": [\n                        {\n                            \"type\": \"text\",\n                            \"text\": {\n                                \"content\": \"✨ Visual overhaul complete! Refresh your Notion page to see changes.\",\n                                \"link\": None\n                            },\n                            \"annotations\": {\n                                \"italic\": True,\n                                \"color\": \"gray\"\n                            }\n                        }\n                    ],\n                    \"color\": \"default\"\n                }\n            }\n        ]\n    }\n    \n    try:\n        url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n        response = requests.patch(url, headers=headers, json=divider_data)\n        \n        if response.status_code == 200:\n            print(\"✅ Added final divider!\")\n        else:\n            print(f\"❌ Failed to add divider: {response.status_code}\")\n            print(response.text)\n            \n    except Exception as e:\n        print(f\"Error: {e}\")\n\n# Run all enhancements\nif __name__ == \"__main__\":\n    print(\"🚀 Starting visual overhaul...\")\n    add_toggle_focus()\n    add_visual_key()\n    update_section_colors()\n    add_final_divider()\n    print(\"\\n🎉 Visual overhaul complete! Check your Notion page.\")"}}],"api":"openai-completions","provider":"nvidia","model":"deepseek-ai/deepseek-v3.2","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774742662591,"responseId":"6dfec4992134443f8cebe8458fd2caea"}}
