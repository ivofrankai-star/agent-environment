{"type":"message","id":"b901c3ff","parentId":"cd8c6a6d","timestamp":"2026-03-29T00:08:43.949Z","message":{"role":"assistant","content":[{"type":"text","text":"Perfect! Let me do one more thing: add icons"},{"type":"toolCall","id":"call_ecd23b9f0e4e475d976d9433","name":"write","arguments":{"file_path":"/home/ivo/.openclaw/workspace/add_icons.py","content":"#!/usr/bin/env python3\nimport os\nimport requests\nimport json\n\n# Get Notion API key from environment\nNOTION_KEY = \"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\"\nPAGE_ID = \"331996240a6680268f4bc68282b2bba6\"\n\nheaders = {\n    \"Authorization\": f\"Bearer {NOTION_KEY}\",\n    \"Notion-Version\": \"2022-06-28\",\n    \"Content-Type\": \"application/json\"\n}\n\ndef add_icons_to_todos():\n    \"\"\"Add icons/emojis to todo items\"\"\"\n    print(\"Adding icons to todo items...\")\n    \n    try:\n        # Get all blocks\n        url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n        response = requests.get(url, headers=headers)\n        blocks = response.json().get('results', [])\n        \n        # Define icon mappings based on content\n        icon_map = {\n            \"Focus Block\": \"🎯\",\n            \"Learn by Doing\": \"🔨\",\n            \"Capture Insights\": \"📝\",\n            \"Review Alignment\": \"🔍\",\n            \"No Shiny Objects\": \"🚫\",\n            \"Ship 1 Project\": \"🚀\",\n            \"Skill Deep Dive\": \"🧠\",\n            \"Income Brainstorm\": \"💰\",\n            \"Review & Purge\": \"🧹\",\n            \"1st Income Stream\": \"💸\",\n            \"Portfolio\": \"📁\",\n            \"Foundation\": \"🏗️\",\n            \"Audience\": \"👥\",\n            \"Self-Trust\": \"💪\"\n        }\n        \n        updated_count = 0\n        \n        for block in blocks:\n            if block.get('type') == 'to_do':\n                todo_text_list = block.get('to_do', {}).get('rich_text', [])\n                if todo_text_list:\n                    todo_text = todo_text_list[0].get('plain_text', '')\n                    \n                    # Find matching icon\n                    icon = None\n                    for keyword, emoji in icon_map.items():\n                        if keyword in todo_text:\n                            icon = emoji\n                            break\n                    \n                    if icon:\n                        # Get block ID\n                        block_id = block['id']\n                        update_url = f\"https://api.notion.com/v1/blocks/{block_id}\"\n                        \n                        # Create new text with icon\n                        new_text = f\"{icon} {todo_text}\"\n                        \n                        update_data = {\n                            \"to_do\": {\n                                \"rich_text\": [\n                                    {\n                                        \"type\": \"text\",\n                                        \"text\": {\n                                            \"content\": new_text,\n                                            \"link\": None\n                                        }\n                                    }\n                                ],\n                                \"checked\": block.get('to_do', {}).get('checked', False)\n                            }\n                        }\n                        \n                        response = requests.patch(update_url, headers=headers, json=update_data)\n                        if response.status_code == 200:\n                            updated_count += 1\n                        else:\n                            print(f\"Failed to update: {todo_text[:30]}...\")\n        \n        print(f\"✅ Added icons to {updated_count} todo items!\")\n        \n    except Exception as e:\n        print(f\"Error: {e}\")\n\nif __name__ == \"__main__\":\n    add_icons_to_todos()"}}],"api":"openai-completions","provider":"nvidia","model":"deepseek-ai/deepseek-v3.2","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774742848969,"responseId":"5eb41f654b9a40e998e69e6f14c897f2"}}
