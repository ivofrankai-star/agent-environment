{"type":"message","id":"48a85ad2","parentId":"8888baf4","timestamp":"2026-03-29T00:34:28.243Z","message":{"role":"assistant","content":[{"type":"text","text":"The order is still weird - database appears first. Let me fix the order by deleting and re-adding properly:"},{"type":"toolCall","id":"chatcmpl-tool-a8f3520b1e7d676d","name":"write","arguments":{"file_path":"/home/ivo/.openclaw/workspace/fix_order.py","content":"#!/usr/bin/env python3\n\"\"\"\nFix block order - Notion API appends at end, so we need to be clever\n\"\"\"\nimport requests\n\nNOTION_KEY = \"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\"\nPAGE_ID = \"331996240a6680268f4bc68282b2bba6\"\nDATABASE_ID = \"33299624-0a66-818e-92d0-dabaca1c1ec8\"\n\nheaders = {\n    \"Authorization\": f\"Bearer {NOTION_KEY}\",\n    \"Notion-Version\": \"2022-06-28\",\n    \"Content-Type\": \"application/json\"\n}\n\ndef delete_block(block_id):\n    url = f\"https://api.notion.com/v1/blocks/{block_id}\"\n    response = requests.delete(url, headers=headers)\n    return response.status_code == 200\n\n# Get current blocks\nurl = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\nresponse = requests.get(url, headers=headers)\nblocks = response.json().get('results', [])\n\nprint(\"🧹 Clearing page (keeping database)...\")\n\n# Delete everything except the database\nfor block in blocks:\n    if block.get('type') != 'child_database':\n        delete_block(block['id'])\n        print(f\"   🗑️  Deleted: {block.get('type')}\")\n\n# Now add clean content BEFORE the database\n# We'll archive the database temporarily and re-add it at the end\n# Actually, Notion doesn't support reordering via API easily\n# The best approach is to just accept the order or use the Notion UI\n\nprint(\"\\n📝 Adding header blocks...\")\n\n# Add header blocks - they will appear AFTER the database in API\n# But in Notion UI, new content typically appears at the top\nheader_blocks = {\n    \"children\": [\n        {\n            \"object\": \"block\",\n            \"type\": \"heading_1\",\n            \"heading_1\": {\n                \"rich_text\": [{\n                    \"type\": \"text\",\n                    \"text\": {\"content\": \"🎯 Ivek's Goals\"},\n                    \"annotations\": {\"bold\": True, \"color\": \"blue\"}\n                }]\n            }\n        },\n        {\n            \"object\": \"block\",\n            \"type\": \"callout\",\n            \"callout\": {\n                \"rich_text\": [{\n                    \"type\": \"text\",\n                    \"text\": {\"content\": \"⚡ Change Status → Progress updates instantly\"}\n                }],\n                \"icon\": {\"emoji\": \"📊\"},\n                \"color\": \"blue_background\"\n            }\n        },\n        {\n            \"object\": \"block\",\n            \"type\": \"divider\",\n            \"divider\": {}\n        }\n    ]\n}\n\nurl = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\nrequests.patch(url, headers=headers, json=header_blocks)\n\nprint(\"✅ Header blocks added!\")\n\n# Final check\nurl = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\nresponse = requests.get(url, headers=headers)\nblocks = response.json().get('results', [])\n\nprint(f\"\\n📋 Page now has {len(blocks)} blocks:\")\nfor i, block in enumerate(blocks):\n    btype = block.get('type')\n    print(f\"   {i+1}. {btype}\")\n\nprint(\"\\n💡 Note: In Notion, the visual order might differ from API order.\")\nprint(\"   If blocks are in wrong order in Notion UI, drag them manually.\")\nprint(\"   (Notion API doesn't support block reordering directly)\")\nprint(\"\\n✨ Done!\")"}}],"api":"openai-completions","provider":"nvidia","model":"z-ai/glm5","usage":{"input":38863,"output":829,"cacheRead":0,"cacheWrite":0,"totalTokens":39692,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774744435817,"responseId":"chatcmpl-89549dbce654a9d1"}}
