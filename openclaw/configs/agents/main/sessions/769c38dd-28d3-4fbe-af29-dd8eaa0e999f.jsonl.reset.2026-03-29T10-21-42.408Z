{"type":"message","id":"51cd2f74","parentId":"3a84eac3","timestamp":"2026-03-29T00:33:34.888Z","message":{"role":"assistant","content":[{"type":"text","text":"The page has some leftover numbered_list_items. Let me do a final cleanup:"},{"type":"toolCall","id":"chatcmpl-tool-a3ea0c83d2c75ea0","name":"write","arguments":{"file_path":"/home/ivo/.openclaw/workspace/final_cleanup.py","content":"#!/usr/bin/env python3\n\"\"\"\nFinal cleanup - remove any remaining junk\n\"\"\"\nimport requests\n\nNOTION_KEY = \"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\"\nPAGE_ID = \"331996240a6680268f4bc68282b2bba6\"\n\nheaders = {\n    \"Authorization\": f\"Bearer {NOTION_KEY}\",\n    \"Notion-Version\": \"2022-06-28\",\n    \"Content-Type\": \"application/json\"\n}\n\ndef delete_block(block_id):\n    url = f\"https://api.notion.com/v1/blocks/{block_id}\"\n    response = requests.delete(url, headers=headers)\n    return response.status_code == 200\n\n# Get all blocks\nurl = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\nresponse = requests.get(url, headers=headers)\nblocks = response.json().get('results', [])\n\nprint(\"🧹 Final cleanup...\")\n\n# Delete numbered_list_items\nfor block in blocks:\n    if block.get('type') == 'numbered_list_item':\n        if delete_block(block['id']):\n            print(f\"   🗑️  Deleted numbered_list_item\")\n\n# Now rebuild the page with clean order\nprint(\"\\n✨ Rebuilding clean page...\")\n\n# Delete everything except database\nfor block in blocks:\n    block_type = block.get('type')\n    if block_type not in ['child_database']:\n        delete_block(block['id'])\n\n# Add clean structure in correct order\nclean_structure = {\n    \"children\": [\n        # Title\n        {\n            \"object\": \"block\",\n            \"type\": \"heading_1\",\n            \"heading_1\": {\n                \"rich_text\": [{\n                    \"type\": \"text\",\n                    \"text\": {\"content\": \"🎯 Ivek's Goals\"},\n                    \"annotations\": {\"bold\": True, \"color\": \"blue\"}\n                }]\n            }\n        },\n        # Simple instruction\n        {\n            \"object\": \"block\",\n            \"type\": \"callout\",\n            \"callout\": {\n                \"rich_text\": [{\n                    \"type\": \"text\",\n                    \"text\": {\"content\": \"Change Status → Progress updates instantly\"}\n                }],\n                \"icon\": {\"emoji\": \"⚡\"},\n                \"color\": \"gray_background\"\n            }\n        },\n        # Divider\n        {\n            \"object\": \"block\",\n            \"type\": \"divider\",\n            \"divider\": {}\n        }\n    ]\n}\n\nurl = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\nrequests.patch(url, headers=headers, json=clean_structure)\n\nprint(\"✅ Done! Page is now clean.\")\nprint(\"\\n📋 Final structure:\")\nprint(\"   🎯 Ivek's Goals (title)\")\nprint(\"   ⚡ Instruction callout\")\nprint(\"   ➖ Divider\")\nprint(\"   📊 Task Tracker Database\")\nprint(\"\\n🔥 Open Notion to see the clean layout!\")"}}],"api":"openai-completions","provider":"nvidia","model":"z-ai/glm5","usage":{"input":37783,"output":676,"cacheRead":0,"cacheWrite":0,"totalTokens":38459,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774744402037,"responseId":"chatcmpl-a5ecdfe97193e3f2"}}
