+284             \"transcript\": transcript_text,\n+285             \"segments\": segments,\n+286             \"word_count\": len(transcript_text.split()),\n+287             \"method\": \"timedtext_api\",\n 235         }\n 236     \n+290     # No transcript available\n 237     return {\n+292         \"error\": \"Could not fetch transcript. The video may not have captions available.\",\n 238         \"video_id\": video_id,\n-239         \"url\": f\"https://www.youtube.com/watch?v={video_id}\",\n+294         \"url\": video_url,\n 240         \"title\": details.get(\"title\"),\n-241         \"duration\": details.get(\"duration\"),\n-242         \"channel\": details.get(\"channel\"),\n 243         \"has_captions\": has_captions,\n-244         \"language\": lang,\n-245         \"transcript\": transcript_text,\n-246         \"segments\": segments,\n-247         \"word_count\": len(transcript_text.split()),\n+297         \"suggestion\": \"Install yt-dlp for better transcript extraction: pip install yt-dlp\",\n 248     }\n 249 \n 250 \n 251 def parse_timedtext_xml(xml_content: str) -> tuple:\n     ...","firstChangedLine":190},"isError":false,"timestamp":1774792782008}}
{"type":"message","id":"eaa10a45","parentId":"81a209ec","timestamp":"2026-03-29T14:00:46.042Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me add the VTT parser function:"},{"type":"toolCall","id":"chatcmpl-tool-973f1db33d95afaa","name":"edit","arguments":{"path":"/home/ivo/.openclaw/workspace/skills/youtube-research/scripts/youtube_search.py","oldText":"def parse_timedtext_xml(xml_content: str) -> tuple:\n    \"\"\"Parse YouTube's timedtext XML format.\"\"\"\n    import xml.etree.ElementTree as ET\n    \n    try:\n        root = ET.fromstring(xml_content)\n    except ET.ParseError:\n        return \"\", []\n    \n    segments = []\n    text_parts = []\n    \n    for child in root:\n        if child.tag == \"text\" or child.tag.endswith(\"}text\"):\n            start = float(child.get(\"start\", 0))\n            duration = float(child.get(\"dur\", 0))\n            text = child.text or \"\"\n            text = text.strip().replace(\"\\n\", \" \")\n            \n            if text:\n                segments.append({\n                    \"start\": start,\n                    \"duration\": duration,\n                    \"text\": text,\n                })\n                text_parts.append(text)\n    \n    return \" \".join(text_parts), segments","newText":"def parse_timedtext_xml(xml_content: str) -> tuple:\n    \"\"\"Parse YouTube's timedtext XML format.\"\"\"\n    import xml.etree.ElementTree as ET\n    \n    try:\n        root = ET.fromstring(xml_content)\n    except ET.ParseError:\n        return \"\", []\n    \n    segments = []\n    text_parts = []\n    \n    for child in root:\n        if child.tag == \"text\" or child.tag.endswith(\"}text\"):\n            start = float(child.get(\"start\", 0))\n            duration = float(child.get(\"dur\", 0))\n            text = child.text or \"\"\n            text = text.strip().replace(\"\\n\", \" \")\n            \n            if text:\n                segments.append({\n                    \"start\": start,\n                    \"duration\": duration,\n                    \"text\": text,\n                })\n                text_parts.append(text)\n    \n    return \" \".join(text_parts), segments\n\n\ndef parse_vtt(vtt_path: str) -> tuple:\n    \"\"\"Parse WebVTT subtitle file.\"\"\"\n    segments = []\n    text_parts = []\n    \n    with open(vtt_path, \"r\", encoding=\"utf-8\") as f:\n        content = f.read()\n    \n    # VTT format:\n    # 00:00:00.000 --> 00:00:05.000\n    # Text content here\n    \n    lines = content.split(\"\\n\")\n    i = 0\n    current_start = 0\n    current_text = []\n    \n    while i < len(lines):\n        line = lines[i].strip()\n        \n        # Look for timestamp lines\n        if \"-->\" in line:\n            # Parse start time\n            start_match = re.match(r\"(\\d+):(\\d+):(\\d+)\\.(\\d+)\", line)\n            if start_match:\n                h, m, s, ms = map(int, start_match.groups())\n                current_start = h * 3600 + m * 60 + s + ms / 1000\n            else:\n                # Try MM:SS.mmm format\n                start_match = re.match(r\"(\\d+):(\\d+)\\.(\\d+)\", line)\n                if start_match:\n                    m, s, ms = map(int, start_match.groups())\n                    current_start = m * 60 + s + ms / 1000\n            \n            # Get text lines following timestamp\n            i += 1\n            current_text = []\n            while i < len(lines) and lines[i].strip() and \"-->\" not in lines[i]:\n                text_line = lines[i].strip()\n                # Remove VTT formatting tags\n                text_line = re.sub(r\"<[^>]+>\", \"\", text_line)\n                if text_line:\n                    current_text.append(text_line)\n                i += 1\n            \n            if current_text:\n                text = \" \".join(current_text)\n                segments.append({\n                    \"start\": current_start,\n                    \"duration\": 0,\n                    \"text\": text,\n                })\n                text_parts.append(text)\n        else:\n            i += 1\n    \n    # Merge consecutive short segments\n    merged_text = []\n    for seg in segments:\n        merged_text.append(seg[\"text\"])\n    \n    return \" \".join(merged_text), segments"}}],"api":"openai-completions","provider":"nvidia","model":"z-ai/glm5","usage":{"input":28715,"output":882,"cacheRead":0,"cacheWrite":0,"totalTokens":29597,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774792782011,"responseId":"chatcmpl-bea4df1f803a1a96"}}
