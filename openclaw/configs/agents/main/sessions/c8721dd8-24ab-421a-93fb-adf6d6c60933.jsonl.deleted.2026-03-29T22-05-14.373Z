{"type":"message","id":"f0884a04","parentId":"d2f7c7fb","timestamp":"2026-03-29T14:51:26.213Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me update the script to use faster-whisper as a fallback:"},{"type":"toolCall","id":"chatcmpl-tool-bca4333058b39722","name":"edit","arguments":{"file":"/home/ivo/.npm-global/lib/node_modules/openclaw/skills/youtube-research/scripts/youtube_search.py","newText":"    # Method 2: yt-dlp + faster-whisper (works from VPS/cloud)\n    if not transcript_text:\n        try:\n            import subprocess\n            import tempfile\n            \n            # Download audio with yt-dlp\n            with tempfile.TemporaryDirectory() as tmpdir:\n                audio_path = os.path.join(tmpdir, \"audio.%(ext)s\")\n                \n                # Download audio only (much smaller)\n                cmd = [\n                    \"yt-dlp\",\n                    \"-x\",  # Extract audio\n                    \"--audio-format\", \"m4a\",\n                    \"--audio-quality\", \"0\",  # Best quality\n                    \"-o\", audio_path,\n                    \"--no-playlist\",\n                    video_url\n                ]\n                result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)\n                \n                # Find the downloaded audio file\n                audio_file = None\n                for fname in os.listdir(tmpdir):\n                    if fname.startswith(\"audio.\"):\n                        audio_file = os.path.join(tmpdir, fname)\n                        break\n                \n                if audio_file and os.path.exists(audio_file):\n                    # Transcribe with faster-whisper\n                    from faster_whisper import WhisperModel\n                    \n                    # Use tiny model for speed, base for better quality\n                    model = WhisperModel(\"tiny\", device=\"cpu\", compute_type=\"int8\")\n                    segments_gen, info = model.transcribe(audio_file, language=lang)\n                    \n                    segments = []\n                    text_parts = []\n                    for seg in segments_gen:\n                        segments.append({\n                            \"start\": seg.start,\n                            \"duration\": seg.end - seg.start,\n                            \"text\": seg.text,\n                        })\n                        text_parts.append(seg.text)\n                    \n                    transcript_text = \" \".join(text_parts)\n                    method_used = \"faster-whisper\"\n                    \n        except ImportError:\n            last_error = last_error or \"faster-whisper not installed. Run: pip install faster-whisper yt-dlp\"\n            pass\n        except subprocess.TimeoutExpired:\n            last_error = \"Video download timed out (too long?)\"\n            pass\n        except Exception as e:\n            last_error = f\"Whisper transcription failed: {str(e)}\"\n            pass","oldText":"    # Method 2: yt-dlp (if youtube-transcript-api failed)\n    if not transcript_text:\n        try:\n            import subprocess\n            import tempfile\n            \n            # Check if yt-dlp is available\n            result = subprocess.run([\"which\", \"yt-dlp\"], capture_output=True)\n            if result.returncode == 0:\n                with tempfile.TemporaryDirectory() as tmpdir:\n                    cmd = [\n                        \"yt-dlp\",\n                        \"--write-auto-sub\",\n                        \"--sub-lang\", lang,\n                        \"--skip-download\",\n                        \"--sub-format\", \"vtt\",\n                        \"-o\", os.path.join(tmpdir, \"video\"),\n                        video_url\n                    ]\n                    result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)\n                    \n                    # Find the .vtt file\n                    for fname in os.listdir(tmpdir):\n                        if fname.endswith(\".vtt\"):\n                            vtt_path = os.path.join(tmpdir, fname)\n                            transcript_text, segments = parse_vtt(vtt_path)\n                            method_used = \"yt-dlp\"\n                            break\n        except Exception:\n            pass"}}],"api":"openai-completions","provider":"nvidia","model":"z-ai/glm5","usage":{"input":50601,"output":726,"cacheRead":0,"cacheWrite":0,"totalTokens":51327,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774795821778,"responseId":"chatcmpl-b6ce4962b332af98"}}
