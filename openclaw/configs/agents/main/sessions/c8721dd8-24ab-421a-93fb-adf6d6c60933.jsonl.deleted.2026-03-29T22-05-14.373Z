{"type":"message","id":"6bb5bff3","parentId":"4f4272ca","timestamp":"2026-03-29T14:37:59.037Z","message":{"role":"assistant","content":[{"type":"text","text":"The API changed - it's now an instantiated class. Let me fix the script:"},{"type":"toolCall","id":"chatcmpl-tool-bb9b26a1e0c479b0","name":"edit","arguments":{"file":"/home/ivo/.npm-global/lib/node_modules/openclaw/skills/youtube-research/scripts/youtube_search.py","oldText":"    # Method 1: youtube-transcript-api (most reliable)\n    try:\n        from youtube_transcript_api import YouTubeTranscriptApi\n        from youtube_transcript_api._errors import TranscriptsDisabled, NoTranscriptFound\n        \n        transcript_list = YouTubeTranscriptApi.list_transcripts(video_id)\n        \n        # Try to get transcript in requested language\n        try:\n            transcript = transcript_list.find_transcript([lang])\n        except NoTranscriptFound:\n            # Try to get any available transcript\n            transcript = transcript_list.find_generated_transcript([lang])\n        \n        transcript_data = transcript.fetch()\n        \n        # Format segments\n        for item in transcript_data:\n            segments.append({\n                \"start\": item.get(\"start\", 0),\n                \"duration\": item.get(\"duration\", 0),\n                \"text\": item.get(\"text\", \"\"),\n            })\n        \n        # Combine text\n        transcript_text = \" \".join([s[\"text\"] for s in segments])\n        method_used = \"youtube-transcript-api\"\n        \n    except ImportError:\n        # Package not installed, fall through to next method\n        pass\n    except Exception as e:\n        # Transcript not available, fall through\n        pass","newText":"    # Method 1: youtube-transcript-api (most reliable)\n    try:\n        from youtube_transcript_api import YouTubeTranscriptApi\n        \n        api = YouTubeTranscriptApi()\n        transcript_data = api.fetch(video_id, languages=[lang])\n        \n        # Format segments\n        for item in transcript_data:\n            segments.append({\n                \"start\": item.get(\"start\", 0),\n                \"duration\": item.get(\"duration\", 0),\n                \"text\": item.get(\"text\", \"\"),\n            })\n        \n        # Combine text\n        transcript_text = \" \".join([s[\"text\"] for s in segments])\n        method_used = \"youtube-transcript-api\"\n        \n    except ImportError:\n        # Package not installed, fall through to next method\n        pass\n    except Exception as e:\n        # Transcript not available, fall through\n        pass"}}],"api":"openai-completions","provider":"nvidia","model":"z-ai/glm5","usage":{"input":44425,"output":479,"cacheRead":0,"cacheWrite":0,"totalTokens":44904,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774795037444,"responseId":"chatcmpl-aaf10af5fbf7f437"}}
