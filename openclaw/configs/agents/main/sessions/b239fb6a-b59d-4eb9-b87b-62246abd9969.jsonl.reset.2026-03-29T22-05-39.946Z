{"type":"message","id":"6e60ca0c","parentId":"2dacb7a4","timestamp":"2026-03-29T12:16:10.926Z","message":{"role":"assistant","content":[{"type":"text","text":"Page is now empty. Now I'll create a comprehensive mini course on prompt engineering:"},{"type":"toolCall","id":"chatcmpl-tool-9cd6714bd263206c","name":"write","arguments":{"file":"/home/ivo/.openclaw/workspace/scripts/notion/create_course.py","content":"#!/usr/bin/env python3\nimport requests\nimport json\n\nNOTION_KEY = \"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\"\nPAGE_ID = \"33299624-0a66-80f8-b532-f1326a1ce59c\"\n\nheaders = {\n    \"Authorization\": f\"Bearer {NOTION_KEY}\",\n    \"Notion-Version\": \"2022-06-28\",\n    \"Content-Type\": \"application/json\"\n}\n\n# Course content - Mini Course on Prompt Engineering\ncourse_blocks = [\n    # Title\n    {\n        \"type\": \"heading_1\",\n        \"heading_1\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"📚 Mini Course: Prompt Engineering for Beginners\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"A practical guide to communicating effectively with AI models. Learn to get better outputs, avoid common mistakes, and structure prompts like a pro.\"}}]\n        }\n    },\n    \n    # Module 1\n    {\n        \"type\": \"heading_2\",\n        \"heading_2\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Module 1: What is Prompt Engineering?\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Prompt engineering is the art of crafting instructions that guide AI models to produce desired outputs. Think of it as learning to speak 'AI language' fluently.\"}}]\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Key Concepts:\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Context: Background information that frames your request\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Instructions: Clear, specific directions for what you want\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Constraints: Rules and limitations (what NOT to do)\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Examples: Sample inputs and outputs that demonstrate your intent\"}}]\n        }\n    },\n    \n    # Module 2\n    {\n        \"type\": \"heading_2\",\n        \"heading_2\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Module 2: The Anatomy of a Good Prompt\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"A well-structured prompt follows this pattern:\"}}]\n        }\n    },\n    {\n        \"type\": \"code\",\n        \"code\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"[CONTEXT] + [SPECIFIC TASK] + [CONSTRAINTS] + [FORMAT]\"}}],\n            \"language\": \"plain text\"\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Example Breakdown:\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [\n                {\"type\": \"text\", \"text\": {\"content\": \"Bad: \"}, \"annotations\": {\"bold\": True}},\n                {\"type\": \"text\", \"text\": {\"content\": \"\\\"Write about dogs\\\"\"}}\n            ]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [\n                {\"type\": \"text\", \"text\": {\"content\": \"Good: \"}, \"annotations\": {\"bold\": True}},\n                {\"type\": \"text\", \"text\": {\"content\": \"\\\"You are a veterinarian writing for new dog owners. Write a 200-word guide on feeding schedules for puppies. Use bullet points. Avoid medical jargon.\\\"\"}}\n            ]\n        }\n    },\n    \n    # Module 3\n    {\n        \"type\": \"heading_2\",\n        \"heading_2\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Module 3: Common Mistakes to Avoid\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [\n                {\"type\": \"text\", \"text\": {\"content\": \"Vague requests: \"}, \"annotations\": {\"bold\": True}},\n                {\"type\": \"text\", \"text\": {\"content\": \"\\\"Make it good\\\" → Be specific about what 'good' means\"}}\n            ]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [\n                {\"type\": \"text\", \"text\": {\"content\": \"Overloading: \"}, \"annotations\": {\"bold\": True}},\n                {\"type\": \"text\", \"text\": {\"content\": \"Too many tasks in one prompt → Split into separate prompts\"}}\n            ]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [\n                {\"type\": \"text\", \"text\": {\"content\": \"Ignoring format: \"}, \"annotations\": {\"bold\": True}},\n                {\"type\": \"text\", \"text\": {\"content\": \"Always specify how you want output structured (bullets, table, JSON)\"}}\n            ]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [\n                {\"type\": \"text\", \"text\": {\"content\": \"No negative constraints: \"}, \"annotations\": {\"bold\": True}},\n                {\"type\": \"text\", \"text\": {\"content\": \"Tell the model what NOT to do (\\\"Do NOT use paragraphs\\\")\"}}\n            ]\n        }\n    },\n    \n    # Module 4\n    {\n        \"type\": \"heading_2\",\n        \"heading_2\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Module 4: Advanced Techniques\"}}]\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"1. Few-Shot Prompting\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Give the model examples to learn from:\"}}]\n        }\n    },\n    {\n        \"type\": \"code\",\n        \"code\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Input: 'The movie was great'\\nSentiment: Positive\\n\\nInput: 'Worst experience ever'\\nSentiment: Negative\\n\\nInput: 'It was okay, nothing special'\\nSentiment: Neutral\\n\\nInput: 'I loved the acting but hated the plot'\\nSentiment:\"}}],\n            \"language\": \"plain text\"\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"2. Chain-of-Thought\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Ask the model to 'think step by step' for complex problems:\"}}]\n        }\n    },\n    {\n        \"type\": \"code\",\n        \"code\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"\\\"Solve this math problem step by step, explaining your reasoning at each stage.\\\"}}],\n            \"language\": \"plain text\"\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"3. Role Prompting\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Assign a specific persona to get specialized outputs:\"}}]\n        }\n    },\n    {\n        \"type\": \"code\",\n        \"code\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"\\\"You are a senior software architect. Review this code and suggest improvements focusing on scalability and maintainability.\\\"}}],\n            \"language\": \"plain text\"\n        }\n    },\n    \n    # Module 5\n    {\n        \"type\": \"heading_2\",\n        \"heading_2\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Module 5: Practical Exercises\"}}]\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Exercise 1: Transform a Bad Prompt\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Bad prompt: \\\"Help me with my resume\\\"\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Your task: Rewrite this using the [CONTEXT] + [TASK] + [CONSTRAINTS] + [FORMAT] structure.\"}}]\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Exercise 2: Create a Few-Shot Prompt\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Create a prompt that classifies customer feedback into categories (product quality, shipping, customer service, other) using 3 examples.\"}}]\n        }\n    },\n    {\n        \"type\": \"heading_3\",\n        \"heading_3\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Exercise 3: Use Negative Constraints\"}}]\n        }\n    },\n    {\n        \"type\": \"paragraph\",\n        \"paragraph\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Write a prompt that explains quantum computing to a 10-year-old, with these rules: no math equations, no paragraphs longer than 2 sentences, must use bullet points.\"}}]\n        }\n    },\n    \n    # Quick Reference\n    {\n        \"type\": \"heading_2\",\n        \"heading_2\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"🎯 Quick Reference: Prompt Template\"}}]\n        }\n    },\n    {\n        \"type\": \"code\",\n        \"code\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"\"\"### CONTEXT\n[Who you are, background, relevant information]\n\n### TASK\n[Specific, clear instruction]\n\n### CONSTRAINTS\n- Do NOT [specific thing to avoid]\n- Keep response under [X] words\n- Use [specific format]\n\n### EXAMPLES\nInput: [example input]\nOutput: [example output]\n\n### OUTPUT FORMAT\n[How you want the response structured]\"\"\"]],\n            \"language\": \"plain text\"\n        }\n    },\n    \n    # Final Tips\n    {\n        \"type\": \"heading_2\",\n        \"heading_2\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"💡 Final Tips\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Iterate: First attempt rarely perfect. Refine based on results.\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Be specific: \\\"3 bullet points\\\" > \\\"a few points\\\"\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Use delimiters: Separate sections with ### or --- for clarity\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Temperature matters: Lower (0.1-0.3) for structured output, higher (0.7-1.0) for creative tasks\"}}]\n        }\n    },\n    {\n        \"type\": \"bulleted_list_item\",\n        \"bulleted_list_item\": {\n            \"rich_text\": [{\"type\": \"text\", \"text\": {\"content\": \"Save what works: Build a personal library of effective prompts\"}}]\n        }\n    },\n]\n\n# Add blocks to page\ndef add_blocks():\n    url = f\"https://api.notion.com/v1/blocks/{PAGE_ID}/children\"\n    \n    # Add in batches (Notion API limit)\n    batch_size = 50\n    for i in range(0, len(course_blocks), batch_size):\n        batch = course_blocks[i:i+batch_size]\n        payload = {\"children\": batch}\n        \n        response = requests.patch(url, headers=headers, json=payload)\n        if response.status_code == 200:\n            print(f\"✅ Added blocks {i+1}-{i+len(batch)}\")\n        else:\n            print(f\"❌ Error adding blocks: {response.status_code}\")\n            print(response.text)\n            break\n    \n    print(\"\\n🎉 Mini course created successfully!\")\n    print(f\"🔗 View here: https://www.notion.so/{PAGE_ID.replace('-', '')}\")\n\nif __name__ == \"__main__\":\n    add_blocks()\n"}}],"api":"openai-completions","provider":"nvidia","model":"z-ai/glm5","usage":{"input":74293,"output":3238,"cacheRead":0,"cacheWrite":0,"totalTokens":77531,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774786381952,"responseId":"chatcmpl-a242874d7e2784ad"}}
